# ──────────────────────────────────────────────
# Slack 설정
# ──────────────────────────────────────────────

# Slack Bot Token (xoxb-로 시작)
# Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack Signing Secret
# Slack App → Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret-here

# #도입문의 채널 ID (C로 시작하는 ID)
# 슬랙 채널 우클릭 → 채널 세부 정보 보기 → 하단에서 채널 ID 복사
# 비워두면 봇이 추가된 모든 채널에 반응합니다
SLACK_CHANNEL_ID=C0123456789

# ──────────────────────────────────────────────
# Anthropic 설정
# ──────────────────────────────────────────────

# Anthropic API Key (sk-ant-로 시작)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ──────────────────────────────────────────────
# 서버 설정 (Railway에서는 자동 설정됨)
# ──────────────────────────────────────────────
PORT=3000
